# OpenClaw bridge — example environment.
# Copy to .env locally; .env is gitignored.

# Bridge runtime
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8788
BRIDGE_LOG_LEVEL=info

# Idempotency-Key cache (SQLite). Migrations run on bridge startup.
BRIDGE_IDEMPOTENCY_DB=~/.openclaw/idempotency.db

# LLM telemetry (SQLite). Schema in bridge/src/bridge/migrations/telemetry_*.sql.
BRIDGE_TELEMETRY_DB=~/.openclaw/telemetry.db

# JSONL access log; rotates daily, 30-day retention.
BRIDGE_ACCESS_LOG=~/.openclaw/access.log

# Tokens live exclusively in macOS Keychain under
# service `com.giuseppelopesme.openclaw.bridge`. Mint with
# scripts/mint-token.py; no env var needed.

# Vault root (Obsidian). Required for vault endpoints; if unset, vault routes
# return 502 dependency_unavailable.
OBSIDIAN_VAULT=/Users/giuseppelopes/Library/Mobile Documents/iCloud~md~obsidian/Documents/GiuseppeLopes

# Redis (event bus + rate limiter). The password lives in macOS Keychain
# under `provider.redis`, not here. These knobs only point at the host.
BRIDGE_REDIS_HOST=127.0.0.1
BRIDGE_REDIS_PORT=6379
BRIDGE_REDIS_DB=0

# OpenRouter — API key lives in macOS Keychain under `provider.openrouter`.
# No env var needed.

# Email — server config (host/port) lives in this TOML file, one section
# per account. Per-account IMAP+SMTP password lives in macOS Keychain
# under `provider.email.{account}`.
BRIDGE_EMAIL_CONFIG=~/.openclaw/email.toml

# Agent drafts (P1a) — bridge-side store for the human-approval flow.
# Schema in bridge/src/bridge/migrations/agent_*.sql.
BRIDGE_AGENT_DB=~/.openclaw/agent.db
