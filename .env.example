# OpenClaw bridge — example environment.
# Copy to .env locally; .env is gitignored.

# Bridge runtime
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8788
BRIDGE_LOG_LEVEL=info

# Legacy dev token store (transitional). Tokens now live in macOS Keychain
# under service `com.giuseppelopesme.openclaw.bridge`. This file is consulted
# only when Keychain enumeration returns zero credentials, and a structured
# warning is logged when that fallback path fires. Removed in Session 3.
BRIDGE_TOKEN_STORE=~/.openclaw/tokens.dev.json

# Idempotency-Key cache (SQLite). Migrations run on bridge startup.
BRIDGE_IDEMPOTENCY_DB=~/.openclaw/idempotency.db

# Telemetry / access log (created on first run; bridge owns these files).
# Wired in Session 3 (LLM router); declared here for forward compatibility.
BRIDGE_TELEMETRY_DB=~/.openclaw/telemetry.db
BRIDGE_ACCESS_LOG=~/.openclaw/access.log

# Vault root (Obsidian). Required for vault endpoints; if unset, vault routes
# return 502 dependency_unavailable.
OBSIDIAN_VAULT=/Users/giuseppelopes/Library/Mobile Documents/iCloud~md~obsidian/Documents/GiuseppeLopes

# Redis — not used in Step 1.
# REDIS_URL=redis://:password@127.0.0.1:6379/0

# OpenRouter — not used in Step 1.
# OPENROUTER_API_KEY=
