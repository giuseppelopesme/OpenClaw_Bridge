# OpenClaw bridge — example environment.
# Copy to .env locally; .env is gitignored.

# Bridge runtime
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8788
BRIDGE_LOG_LEVEL=info

# Dev token store (Step 1 only — replaced by macOS Keychain in a later step).
# Path is expanded with ~ and read on bridge startup.
BRIDGE_TOKEN_STORE=~/.openclaw/tokens.dev.json

# Telemetry / access log (created on first run; bridge owns these files).
BRIDGE_TELEMETRY_DB=~/.openclaw/telemetry.db
BRIDGE_ACCESS_LOG=~/.openclaw/access.log

# Vault root (Obsidian). Required for vault provider — not used in Step 1.
# OBSIDIAN_VAULT=/Users/giuseppelopes/Library/Mobile Documents/iCloud~md~obsidian/Documents/GiuseppeLopes

# Redis — not used in Step 1.
# REDIS_URL=redis://:password@127.0.0.1:6379/0

# OpenRouter — not used in Step 1.
# OPENROUTER_API_KEY=
